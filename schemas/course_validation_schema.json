{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "The God Factory University Course",
  "description": "Validation schema for course JSON imports.",
  "type": "object",
  "required": ["title", "modules"],
  "properties": {
    "course_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique course identifier, e.g. CS-101, MATH-201, BIO-401"
    },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "credits": { "type": "integer", "minimum": 1, "maximum": 6 },
    "difficulty_level": {
      "type": "string",
      "enum": [
        "K-5", "6-8", "9-12",
        "Freshman", "Sophomore", "Junior", "Senior",
        "Masters", "Doctoral", "Postdoctoral"
      ],
      "description": "Granular grade/college level for the course"
    },
    "recommended_prerequisites": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Array of course_ids that should be completed before this course"
    },
    "parent_course_id": {
      "type": "string",
      "description": "ID of parent course for recursive sub-course trees. NULL or absent for root courses."
    },
    "depth_level": {
      "type": "integer",
      "minimum": 0,
      "description": "Depth in the course tree. 0 = root, 1+ = sub-course."
    },
    "depth_target": {
      "type": "integer",
      "minimum": 0,
      "description": "Expected number of decomposition levels before full credit is earned."
    },
    "pacing": {
      "type": "string",
      "enum": ["fast", "standard", "slow"],
      "description": "Delivery speed: fast (multi-concept), standard (1 per lecture), slow (multi-lecture per concept)."
    },
    "jargon": {
      "type": "object",
      "description": "Domain terminology for this course — key terms, definitions, etymology, usage.",
      "properties": {
        "terms": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["term", "definition"],
            "properties": {
              "term": { "type": "string" },
              "definition": { "type": "string" },
              "etymology": { "type": "string" },
              "usage_example": { "type": "string" },
              "related_terms": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "is_jargon_course": {
      "type": "boolean",
      "description": "True if this is a terminology-focused companion course."
    },
    "recommended_textbooks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Suggested reference materials"
    },
    "learning_outcomes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "High-level outcomes the student should achieve after completion"
    },
    "assignments": {
      "type": "array",
      "items": { "$ref": "#/definitions/assignment" },
      "description": "Course assignments sent after course creation"
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "lectures"],
        "properties": {
          "module_id": {
            "type": "string",
            "description": "Should incorporate course_id prefix, e.g. CS-101-M01"
          },
          "title": { "type": "string", "minLength": 1 },
          "lectures": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["title"],
              "properties": {
                "lecture_id": {
                  "type": "string",
                  "description": "Should incorporate module_id prefix, e.g. CS-101-M01-L01"
                },
                "title": { "type": "string", "minLength": 1 },
                "duration_min": { "type": "number", "minimum": 1 },
                "prerequisites": { "type": "array", "items": { "type": "string" } },
                "learning_objectives": { "type": "array", "items": { "type": "string" } },
                "core_terms": { "type": "array", "items": { "type": "string" } },
                "video_recipe": {
                  "type": "object",
                  "properties": {
                    "narrative_arc": { "type": "array", "items": { "type": "string" } },
                    "scene_blocks": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["narration_prompt"],
                        "properties": {
                          "block_id": { "type": "string" },
                          "duration_s": { "type": "number", "minimum": 1 },
                          "narration_prompt": { "type": "string", "minLength": 1 },
                          "visual_prompt": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "assignment": {
      "type": "object",
      "required": ["title", "type"],
      "properties": {
        "assignment_id": {
          "type": "string",
          "description": "Unique ID using course prefix, e.g. CS-101-A01"
        },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["quiz", "homework", "project", "essay", "lab", "exam", "midterm", "final"]
        },
        "difficulty_level": {
          "type": "string",
          "enum": [
            "K-5", "6-8", "9-12",
            "Freshman", "Sophomore", "Junior", "Senior",
            "Masters", "Doctoral", "Postdoctoral"
          ]
        },
        "max_score": { "type": "integer", "minimum": 1, "default": 100 },
        "weight": { "type": "number", "minimum": 0, "maximum": 1.0 },
        "due_after_lecture": {
          "type": "string",
          "description": "lecture_id after which this assignment is due"
        },
        "rubric": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["criterion", "points"],
            "properties": {
              "criterion": { "type": "string" },
              "points": { "type": "integer", "minimum": 0 },
              "description": { "type": "string" }
            }
          }
        },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["prompt"],
            "properties": {
              "prompt": { "type": "string" },
              "question_type": {
                "type": "string",
                "enum": ["multiple_choice", "true_false", "short_answer", "essay", "code"]
              },
              "choices": { "type": "array", "items": { "type": "string" } },
              "correct_answer": { "type": "string" },
              "points": { "type": "integer", "minimum": 1 }
            }
          }
        },
        "ai_policy": {
          "type": "object",
          "description": "AI usage policy for this assignment.",
          "properties": {
            "level": {
              "type": "string",
              "enum": ["unrestricted", "assisted", "supervised", "prohibited"],
              "description": "Overall AI policy level."
            },
            "allowed_uses": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Specific AI uses permitted (e.g., 'grammar checking', 'chart generation')."
            },
            "prohibited_uses": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Specific AI uses forbidden (e.g., 'code generation', 'answer completion')."
            },
            "verification_type": {
              "type": "string",
              "enum": ["none", "original_example", "oral_explanation", "peer_review"],
              "description": "How student must prove understanding after AI-assisted work."
            }
          }
        }
      }
    }
  },
  "additionalProperties": true
}
