{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "The God Factory University Assignment Batch",
  "description": "Standalone assignment schema sent to LLM after course creation. Keeps assignment context separate from the course schema to avoid overloading the LLM context window.",
  "type": "object",
  "required": ["course_id", "assignments"],
  "properties": {
    "course_id": {
      "type": "string",
      "minLength": 1,
      "description": "The course this batch of assignments belongs to, e.g. CS-101"
    },
    "course_title": {
      "type": "string",
      "description": "Human-readable course title for reference"
    },
    "assignments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "type"],
        "properties": {
          "assignment_id": {
            "type": "string",
            "description": "Unique ID using course prefix, e.g. CS-101-A01, CS-101-Q01"
          },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["quiz", "homework", "project", "essay", "lab", "exam", "midterm", "final"]
          },
          "difficulty_level": {
            "type": "string",
            "enum": [
              "K-5", "6-8", "9-12",
              "Freshman", "Sophomore", "Junior", "Senior",
              "Masters", "Doctoral"
            ]
          },
          "max_score": { "type": "integer", "minimum": 1, "default": 100 },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1.0,
            "description": "Weight of this assignment toward final grade (0.0–1.0)"
          },
          "due_after_lecture": {
            "type": "string",
            "description": "lecture_id after which this assignment becomes due"
          },
          "time_limit_minutes": {
            "type": "integer",
            "minimum": 1,
            "description": "Time limit for timed assessments like quizzes/exams"
          },
          "rubric": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["criterion", "points"],
              "properties": {
                "criterion": { "type": "string", "minLength": 1 },
                "points": { "type": "integer", "minimum": 0 },
                "description": { "type": "string" }
              }
            }
          },
          "questions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["prompt"],
              "properties": {
                "prompt": { "type": "string", "minLength": 1 },
                "question_type": {
                  "type": "string",
                  "enum": ["multiple_choice", "true_false", "short_answer", "essay", "code"]
                },
                "choices": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Options for multiple_choice questions"
                },
                "correct_answer": {
                  "type": "string",
                  "description": "Expected answer for auto-grading"
                },
                "points": { "type": "integer", "minimum": 1, "default": 1 },
                "explanation": {
                  "type": "string",
                  "description": "Explanation shown after grading"
                }
              }
            }
          },
          "resources": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Reference materials or links helpful for the assignment"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
